<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:16px;">{{ 'general.search.title' | t }}</h1>
  <form action="{{ routes.search_url }}" method="get" style="margin-bottom:24px;">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" style="width:100%;padding:12px 16px;border:1px solid #E8E4D6;border-radius:8px;font-size:15px;">
  </form>
  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="color:#62717D;">{{ 'general.search.no_results' | t }}</p>
    {%- else -%}
      <ul style="list-style:none;padding:0;margin:0;">
        {%- for item in search.results -%}
          <li style="padding:12px 0;border-bottom:1px solid #E8E4D6;">
            <a href="{{ item.url }}" style="color:#0A2633;text-decoration:none;font-weight:600;">{{ item.title }}</a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search"
}
{% endschema %}
