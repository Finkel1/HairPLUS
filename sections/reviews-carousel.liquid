<section class="section section--cream">
  <div class="container-x">
    <div class="text-center">
      <h2 class="reviews-carousel__heading" style="font-size:clamp(1.875rem,4vw,3rem)">{{ section.settings.heading }}</h2>
      <div class="rating-summary" style="justify-content:center">
        {% render 'star-rating', count: 5 %}
        <span style="font-weight:700">{{ section.settings.rating }}</span>
        <span class="text-muted">({{ section.settings.review_count }})</span>
        <span class="text-muted" style="display:inline-flex;align-items:center;gap:0.375rem;border:1px solid var(--border);border-radius:9999px;padding:0.25rem 0.75rem;font-size:0.75rem;font-weight:700;background:var(--white)">
          {% render 'icon', name: 'badge-check', class: 'icon icon--sm icon--pink' %} Verificado
        </span>
      </div>
    </div>

    {% render 'reviews-carousel-core', section: section %}

    <div class="section-bundle-cta">
      {% render 'scroll-to-bundle-cta' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Carrusel de reseñas",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Todas las reseñas" },
    { "type": "text", "id": "rating", "label": "Puntuación", "default": "4.78" },
    { "type": "text", "id": "review_count", "label": "Cantidad", "default": "1029" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reseña",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto" },
        {
          "type": "text",
          "id": "fallback_image",
          "label": "Foto por defecto (ruta en assets)",
          "default": "review-norma-videla.jpg"
        },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Excelente producto." },
        { "type": "text", "id": "name", "label": "Nombre", "default": "Cliente" },
        {
          "type": "range",
          "id": "stars",
          "label": "Estrellas",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carrusel de reseñas",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-norma-videla.jpg",
            "text": "Me lo compré para eventos especiales, funcionó perfecto. Ahora lo uso todo el tiempo. Muy buena.",
            "name": "Norma Videla",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-patricia-lugones.jpg",
            "text": "Cubre bien, dura todo el día y no se nota que usaste nada. Ya había comprado dos productos similares que no funcionaban.",
            "name": "Patricia Lugones",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-viviana-alvarez.jpg",
            "text": "Probé tres sprays distintos antes de encontrar este polvo. Todos prometían y ninguno cumplía. Este sí.",
            "name": "Viviana Alvarez",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-claudia-brizuela.jpg",
            "text": "Siempre me peinaba de una forma para tapar la raíz. Desde que tengo este polvo uso el pelo como quiero.",
            "name": "Claudia Brizuela",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-carolina-bravo.jpg",
            "text": "Da densidad y tapa las partes faltantes. Podés mojarte tranquila que no se va a salir ni correr.",
            "name": "Carolina Bravo",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-miriam-lopez.jpg",
            "text": "Me gusta cómo queda y no es un enchastre como el L'Oréal Magic Retouch que es en spray y salpica.",
            "name": "Miriam Lopez",
            "stars": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-marisa-irazusta.jpg",
            "text": "Lo compré con dudas porque ya había probado cosas que no funcionaron. Funciona bien.",
            "name": "Marisa Irazusta",
            "stars": 4
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-ana-villalba.jpg",
            "text": "Muy bueno, cubre bien y no mancha. El tono me quedó apenas más claro de lo que esperaba pero igual me gustó.",
            "name": "Ana Villalba",
            "stars": 4
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-silvia-romero.jpg",
            "text": "Me salva siempre, me queda el pelo como si recién saliera de la pelu. Lo amo.",
            "name": "Silvia Romero",
            "stars": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
