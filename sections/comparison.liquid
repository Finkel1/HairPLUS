<section class="section section--white">
  <div class="container-x">
    <div class="section-header">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="comparison-visual">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            class: 'comparison-visual__img',
            loading: 'lazy',
            alt: section.settings.image_alt,
            widths: '400, 600, 800, 1000, 1200, 1400',
            sizes: '(min-width: 768px) 640px, 100vw'
        }}
      {%- else -%}
        <img
          class="comparison-visual__img"
          src="{{ 'comparison-section.png' | asset_url }}"
          alt="{{ section.settings.image_alt | escape }}"
          loading="lazy"
          width="800"
          height="900"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparación",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "La diferencia" },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Por qué el polvo funciona mejor que el spray?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen comparación",
      "info": "Si está vacío, se usa comparison-section.png del tema."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo",
      "default": "Spray tradicional vs polvo HairPLUS"
    }
  ],
  "presets": [{ "name": "Comparación" }]
}
{% endschema %}
