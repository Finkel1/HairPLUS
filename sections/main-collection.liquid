<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:16px;">{{ collection.title }}</h1>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">
        {%- if product.featured_image -%}
          {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', style: 'width:100%;border-radius:8px;' }}
        {%- endif -%}
        <p style="font-size:13px;font-weight:600;margin:8px 0 4px;">{{ product.title }}</p>
        <p style="font-size:13px;color:#62717D;margin:0;">{{ product.price | money }}</p>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection"
}
{% endschema %}
