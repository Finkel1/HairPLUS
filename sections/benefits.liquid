<section class="section section--cream">
  <div class="container-x">
    <div class="section-header">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="grid-3 mt-10">
      {%- for block in section.blocks -%}
        <article class="benefit-card" {{ block.shopify_attributes }}>
          <div class="benefit-card__head">
            <span class="benefit-card__icon">
              {% render 'icon', name: block.settings.icon, class: 'icon' %}
            </span>
            <h3>{{ block.settings.title }}</h3>
          </div>
          <p>{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
    <div class="benefits-cta">
      {% render 'scroll-to-bundle-cta' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beneficios",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Beneficios" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Todo lo que necesitás en un solo gesto." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icono", "default": "sparkles", "options": [
          { "value": "sparkles", "label": "Brillo" },
          { "value": "shield", "label": "Escudo" },
          { "value": "clock", "label": "Reloj" },
          { "value": "droplets", "label": "Gotas" },
          { "value": "wind", "label": "Viento" },
          { "value": "scissors", "label": "Tijeras" },
          { "value": "shield-check", "label": "Escudo check" },
          { "value": "rotate", "label": "Rotar" },
          { "value": "badge-check", "label": "Verificado" }
        ]},
        { "type": "text", "id": "title", "label": "Título", "default": "Cubre canas al instante" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Resultado visible apenas lo aplicás." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "sparkles", "title": "Cubre canas al instante", "text": "Resultado visible apenas lo aplicás." } },
        { "type": "benefit", "settings": { "icon": "shield", "title": "Oculta entradas visibles", "text": "Suma densidad donde más necesitás." } },
        { "type": "benefit", "settings": { "icon": "clock", "title": "Cubre raíces al instante", "text": "Retocá el crecimiento sin ir al salón." } },
        { "type": "benefit", "settings": { "icon": "droplets", "title": "No mancha ropa", "text": "Se queda en el pelo, no en tu remera." } },
        { "type": "benefit", "settings": { "icon": "wind", "title": "Resiste el día a día", "text": "Aguanta sudor, viento y lluvia ligera." } },
        { "type": "benefit", "settings": { "icon": "scissors", "title": "Se elimina con shampoo", "text": "Lavás y listo, sin residuos." } },
        { "type": "benefit", "settings": { "icon": "shield-check", "title": "Menos peluquería", "text": "Estirá tu coloración varias semanas más." } }
      ]
    }
  ]
}
{% endschema %}
