<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:16px;">{{ blog.title }}</h1>
  {%- for article in blog.articles -%}
    <article style="margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid #E8E4D6;">
      <h2 style="font-size:1.125rem;margin-bottom:8px;"><a href="{{ article.url }}" style="color:#0A2633;text-decoration:none;">{{ article.title }}</a></h2>
      <p style="font-size:14px;color:#62717D;line-height:1.6;">{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>
    </article>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "class": "section-main-blog"
}
{% endschema %}
