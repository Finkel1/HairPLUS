<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;text-align:center;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:8px;">{{ shop.name }}</h1>
  <p style="color:#62717D;margin-bottom:24px;">{{ 'general.password_page.login_form_heading' | t }}</p>
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}" style="width:100%;padding:12px 16px;border:1px solid #E8E4D6;border-radius:8px;font-size:15px;margin-bottom:12px;">
    <button type="submit" style="width:100%;background:#0A2633;color:#F9FAF8;border:none;padding:14px;border-radius:999px;font-weight:700;cursor:pointer;">{{ 'general.password_page.login_form_submit' | t }}</button>
  {% endform %}
</div>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "class": "section-main-password"
}
{% endschema %}
