<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;text-align:center;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:8px;">{{ 'general.404.title' | t }}</h1>
  <p style="color:#62717D;margin-bottom:24px;">{{ 'general.404.subtext' | t }}</p>
  <a href="{{ routes.root_url }}" style="display:inline-block;background:#0A2633;color:#F9FAF8;padding:12px 24px;border-radius:999px;text-decoration:none;font-weight:600;">{{ 'cart.general.continue_shopping' | t }}</a>
</div>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-main-404"
}
{% endschema %}
