<section class="section section--cream">
  <div class="container-x">
    <h1 style="font-size:clamp(1.875rem,4vw,2.5rem)">{{ 'sections.cart.title' | t }}</h1>
    {%- if cart.item_count == 0 -%}
      <p class="text-muted" style="margin-top:1rem">Tu carrito está vacío.</p>
      <a href="{% render 'product-cta-url' %}" class="btn-primary" style="margin-top:1.5rem;display:inline-flex">Ver producto</a>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" style="margin-top:2rem">
        <table style="width:100%;border-collapse:collapse">
          <thead>
            <tr style="border-bottom:1px solid var(--border);text-align:left">
              <th style="padding:0.75rem 0">Producto</th>
              <th>Cantidad</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:1rem 0">{{ item.product.title }} — {{ item.variant.title }}</td>
                <td><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:4rem;padding:0.375rem;border:1px solid var(--border);border-radius:0.375rem"></td>
                <td>{{ item.line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
        <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:1rem;align-items:center;justify-content:space-between">
          <button type="submit" name="update" class="btn-secondary">Actualizar carrito</button>
          <div style="font-size:1.25rem;font-weight:900">Total: {{ cart.total_price | money }}</div>
          <button type="submit" name="checkout" class="btn-dark">Finalizar compra</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Carrito",
  "settings": []
}
{% endschema %}
