<div class="hp-minimal" style="font-family:system-ui,sans-serif;max-width:480px;margin:48px auto;padding:0 24px;color:#0A2633;">
  <h1 style="font-size:1.5rem;margin-bottom:16px;">{{ 'cart.general.title' | t }}</h1>
  {%- if cart.item_count == 0 -%}
    <p style="color:#62717D;margin-bottom:24px;">{{ 'cart.general.empty' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" style="display:inline-block;background:#0A2633;color:#F9FAF8;padding:12px 24px;border-radius:999px;text-decoration:none;font-weight:600;">{{ 'cart.general.continue_shopping' | t }}</a>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post">
      <ul style="list-style:none;padding:0;margin:0 0 24px;">
        {%- for item in cart.items -%}
          <li style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid #E8E4D6;">
            <span>{{ item.product.title }} × {{ item.quantity }}</span>
            <span>{{ item.final_line_price | money }}</span>
          </li>
        {%- endfor -%}
      </ul>
      <p style="font-weight:700;margin-bottom:16px;">Total: {{ cart.total_price | money }}</p>
      <button type="submit" name="checkout" style="width:100%;background:#B8AA88;color:#0A2633;border:none;padding:16px;border-radius:999px;font-weight:700;font-size:16px;cursor:pointer;">Checkout</button>
    </form>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart"
}
{% endschema %}
