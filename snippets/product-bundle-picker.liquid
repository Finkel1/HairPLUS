{%- comment -%}
  Bundle picker: precios de marketing + color por unidad + add to cart (1+ variantes).
{%- endcomment -%}
{%- assign default_qty = section.settings.default_bundle_qty | default: 1 -%}

{%- assign color_option = nil -%}
{%- assign color_option_index = 0 -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_name = option.name | downcase -%}
  {%- if opt_name contains 'color' or opt_name contains 'tono' or opt_name contains 'colour' -%}
    {%- assign color_option = option -%}
    {%- assign color_option_index = forloop.index0 -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- if color_option == nil and product.has_only_default_variant == false -%}
  {%- assign color_option = product.options_with_values.first -%}
  {%- assign color_option_index = 0 -%}
{%- endif -%}

<div
  class="bundle-list"
  data-bundle-list
  data-color-option-index="{{ color_option_index }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
>
  {%- assign bundle_blocks = section.blocks | where: 'type', 'bundle' -%}

  {%- if bundle_blocks.size == 0 -%}
    {%- assign bundle_defaults = 'Llevá 1|1|||$39.899|$39.899,Llevá 2|2|Más Popular|/cu|$29.980|$59.960,Llevá 3|3|Mejor Valor|/cu|$25.980|$77.940' | split: ',' -%}
    {%- for item in bundle_defaults -%}
      {%- assign parts = item | split: '|' -%}
      {%- assign qty = parts[1] | plus: 0 -%}
      {%- render 'product-bundle-option',
        qty: qty,
        label: parts[0],
        badge: parts[2],
        unit_suffix: parts[3],
        price: parts[4],
        total_label: parts[5],
        default_qty: default_qty,
        color_option: color_option,
        section: section
      -%}
    {%- endfor -%}
  {%- else -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'bundle' -%}
        {%- assign qty = block.settings.quantity | default: 1 | plus: 0 -%}
        {%- assign price = block.settings.price | default: '' -%}
        {%- assign total_label = block.settings.total_label | default: price -%}
        {%- assign compare_price = '' -%}
        {%- if qty > 1 -%}
          {%- capture compare_price -%}{%- render 'bundle-compare-price', qty: qty, section: section -%}{%- endcapture -%}
          {%- assign compare_price = compare_price | strip -%}
        {%- endif -%}
        <div
          class="bundle-option{% if qty == default_qty %} is-selected{% endif %}"
          data-bundle-option
          data-qty="{{ qty }}"
          data-total-label="{{ total_label | escape }}"
          {% if qty > 1 and compare_price != blank %}data-compare-label="{{ compare_price | escape }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.badge != blank -%}
            <span class="bundle-option__badge">{{ block.settings.badge }}</span>
          {%- endif -%}
          <button
            type="button"
            class="bundle-option__btn"
            data-bundle-select
            aria-pressed="{% if qty == default_qty %}true{% else %}false{% endif %}"
          >
            <span class="bundle-option__radio" aria-hidden="true"></span>
            <span class="bundle-option__content">
              <span class="bundle-option__row">
                <span class="bundle-option__left">
                  <span class="bundle-option__label">{{ block.settings.label }}</span>
                  <span class="bundle-option__sub">Envío Gratis + 3 Cuotas</span>
                </span>
                <span class="bundle-option__prices">
                  {%- if price != blank -%}
                    <span class="bundle-option__price">{{ price }}{% if block.settings.unit_suffix != blank %}<span class="bundle-option__unit">{{ block.settings.unit_suffix }}</span>{% endif %}</span>
                  {%- endif -%}
                  {%- if qty > 1 and compare_price != blank -%}
                    <span class="bundle-option__compare">{{ compare_price }}</span>
                  {%- endif -%}
                </span>
              </span>
            </span>
          </button>
          {%- if color_option -%}
            <div class="bundle-option__colors" data-bundle-colors>
              <div class="bundle-option__colors-label">Color</div>
              <div class="bundle-option__color-slots">
                {%- for i in (1..qty) -%}
                  {%- capture slot_label -%}Color unidad {{ i }}{%- endcapture -%}
                  <div class="bundle-color-slot">
                    <span class="bundle-color-slot__num">#{{ i }}</span>
                    {% render 'bundle-color-select', color_option: color_option, slot_label: slot_label %}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  <script type="application/json" data-variant-stock-json>
    [
      {%- for variant in product.variants -%}
        {%- assign variant_color = variant.options[color_option_index] -%}
        {
          "id": {{ variant.id }},
          "color": {{ variant_color | json }},
          "available": {{ variant.available | json }},
          "inventory_management": {{ variant.inventory_management | json }},
          "inventory_policy": {{ variant.inventory_policy | json }},
          "inventory_quantity": {% if variant.inventory_management %}{{ variant.inventory_quantity | default: 0 }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</div>

<input type="hidden" name="quantity" value="{{ default_qty }}" data-quantity min="1">

<div class="bundle-summary">
  <div class="bundle-summary__row">
    <span class="bundle-summary__label">Total:</span>
    <span class="bundle-summary__total" data-product-price></span>
    <span class="bundle-summary__compare" data-product-compare hidden></span>
  </div>
</div>

<button
  type="submit"
  name="add"
  class="btn-dark btn-full"
  data-add-to-cart
  {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
>
  {% render 'icon', name: 'cart', class: 'icon icon--sm' %}
  <span data-add-to-cart-label>
    {%- if product.selected_or_first_available_variant.available -%}
      {{ 'products.product.add_to_cart' | t }}
    {%- else -%}
      {{ 'products.product.sold_out' | t }}
    {%- endif -%}
  </span>
</button>
